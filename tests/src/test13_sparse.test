#! /bin/sh

set -e
set -u

. ${tstdir-.}/lib.sh
. ${tstdir-.}/conf.sh

mksparse=${tstdir-.}/mksparse

rm -rf dir1 dir2 dir3 sparsefile sparsefile.report

# make the copy-from-here tree
mkdir dir1
# Actually write(2) nulls so that the file shouldn't be sparse unless
# compressed.
$mksparse -n -c -h 2 -d 2 dir1/sparsefile

# We'll also stash off a copy that we sparsify to compare hole reports against.
cp dir1/sparsefile .
$mksparse sparsefile
$mksparse -r sparsefile > sparsefile.report
if [ ! -s sparsefile.report ]; then
	1>&2 echo "Failed to sparsify our initial file"
	exit 1
fi

# make the tree we want to compare to
mkdir dir2
$mksparse -c -h 2 -d 2 dir2/sparsefile

mkdir dir3

# On modern filesystems, it's sometimes hard to avoid it implicitly compressing
# zeroes in files as they're being written, so we don't even try to confirm that
# rsync *without* --sparse isn't writing holes out.
rsync -a --sparse -- dir1/ dir3
$mksparse -r dir3/sparsefile > dir3/sparsefile.report
cmp sparsefile.report dir3/sparsefile.report
